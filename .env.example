# --- BeWell AssetIQ: Centralized Environment Configuration ---

# Node Environment
NODE_ENV=development
PORT=4000

# Frontend & Security
FRONTEND_URL=http://localhost:5173
JWT_SECRET=your_jwt_secret_here

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/bewell_assetiq

# Redis (Caching & BullMQ)
REDIS_URL=redis://localhost:6379

# Cloudflare R2 (Asset Storage)
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY_ID=your_access_key
R2_SECRET_ACCESS_KEY=your_secret_key
R2_BUCKET_NAME=bewell-assets
R2_PUBLIC_URL=https://assets.bewell.in

# SMTP (Email Notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=notifications@bewell.in
SMTP_PASS=your_smtp_password
SMTP_FROM="BeWell AssetIQ <notifications@bewell.in>"

# Twilio (SMS Alerts)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_FROM_NUMBER=+1234567890
ALERT_SMS_ENABLED=false

# Sentry (Error Tracking)
SENTRY_DSN=your_sentry_dsn

# Puppeteer (PDF Generation)
# Required for some environments (Docker)
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/google-chrome-stable

# --- Frontend (Vite) Specific ---
VITE_API_URL=http://localhost:4000/api
VITE_SOCKET_URL=http://localhost:4000
